#include<stdio.h>

int insertion(int a[],int n);
void deletion(int a[],int n);
void merge(int a[],int n);
void traversal(int a[],int n);

int main()
{
	int a[100],n,i,op;
	printf("Enter the number of elements of 1st array:");
	scanf("%d",&n);
	printf("Enter the elements:\n");
	for (i=0;i<n;i++)
	{
		scanf("%d",&a[i]);
	}

	do
	{

	printf("Enter the opertion you want to execute:\n 1-Insertion\n 2-Deletion\n 3-Merge\n 4-Traverson\n 5-Exit from the programme\n");
	scanf("%d",&op);
	switch(op)
	{
		case 1:
			insertion(a,n);
				break;
		case 2:
			deletion(a,n);
				break;
		case 3:
			merge(a,n);
                	        break;
		case 4:
			traversal(a,n);
                	        break;
		case 5:
                        printf("Exit programme\n");
                                break;
		default :
			printf("Invalid Selection\n");
	}
	}while(op!=5);
	return 0;
}

int insertion(int a[],int n)
{
	int i,num,pos;
	printf("Enter the number to be inserted:");
	scanf("%d",&num);
	printf("Enter the position of the element to be inserted:");
	scanf("%d",&pos);
	for(i=n;i>=pos;i--)
	{
		a[i]=a[i-1];
	}
	a[pos-1]=num;
	n++;
	printf("They new array is:");
	for(i=0;i<n;i++)
	{
		printf("%d\n",a[i]);
	}
	return n;
}

void deletion(int a[],int n)
{
	int i,pos;
	printf("Enter the position of the element to be deleted:");
	scanf("%d",&pos);
	for(i=pos-1;i<n-1;i++)
	{
		a[i]=a[i+1];
	}
	n--;
	printf("The modified array is:");
	for(i=0;i<n-1;i++)
	{
		printf("%d\n",a[i]);
	}
}

void merge(int a[],int n)
{
 	int b[100],c[100],i,m,l;
 	printf("Enter the number of elements of 2nd array:");
 	scanf("%d",&m);
 	printf("Enter the elements:");
 	for (i=0;i<m;i++)
	{
 	       scanf("%d",&b[i]);
 	}
	for (i=0;i<n;i++)
	{
		c[i]=a[i];
	}
	for (i=0;i<m;i++)
	{
		c[i+n]=b[i];
	}
	printf("The merged array is:\n");
	l=m+n;
	for(i=0;i<l;i++)
	{
		printf("%d\n",c[i]);
	}
}

void traversal(int a[],int n)
{
	int i;
	printf("The array is:");
	for (i=0;i<n;i++)
	{
        	printf("%d\n",a[i]);
	}
}
